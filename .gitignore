# Virtual environments
.venv/

# Model artifacts (large binaries; reproducible via src/train.py)
models/*.joblib

# Dataset: the full assessment dataset (data/trellis_assessment_ds) and any
# other large/proprietary corpora are NOT committed; place them locally to run
# the full pipeline. The small synthetic sample corpus (data/sample) IS tracked
# so a clean clone can train a smoke model and serve predictions out of the box.
/data/*
!/data/.gitkeep
!/data/sample/

# Python caches
__pycache__/
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/

# Coverage artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/

# Note: reports/*.csv, reports/*.json, and reports/*.txt are deliberately
# tracked — small generated report artifacts are part of the deliverable.

# Internal review-remediation working notes (not part of deliverable)
docs/REVIEW_REMEDIATION.md
